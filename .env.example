# Copy to .env for local Docker Compose runs.
# Compose will read .env automatically. Do NOT commit your real .env.

# PostgreSQL
POSTGRES_USER=smartics
POSTGRES_PASSWORD=smartics
POSTGRES_DB=smartics
POSTGRES_URL=postgres://smartics:smartics@postgres:5432/smartics?sslmode=disable

# Kafka
KAFKA_BROKERS=kafka:9092
KAFKA_TOPIC=smartics.events

# API
HTTP_ADDR=:8080
LOG_LEVEL=info
