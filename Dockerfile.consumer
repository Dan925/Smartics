# Multi-stage build for the consumer binary.
# Activated in Step 13 of the Checkpoint 1 plan once cmd/consumer exists.

FROM golang:1.22-alpine AS build
WORKDIR /src

COPY go.mod go.sum* ./
RUN go mod download || true

COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -trimpath -ldflags="-s -w" -o /out/consumer ./cmd/consumer

FROM gcr.io/distroless/static-debian12:nonroot
COPY --from=build /out/consumer /consumer
USER nonroot:nonroot
ENTRYPOINT ["/consumer"]
